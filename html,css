css





*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Georgia, 'Times New Roman', Times, serif;
}
body{
    background:rgb(229, 240, 234);
}

.container{
    max-width: 100%;
    margin: auto;
    padding: 20px;
}

.header{
    display: flex;
    justify-content: space-between;
    align-items: center;

}
.header h1{
    color: black;
}
.header p{
    font-size: 14px;
    color: black;
}

.header-actions{
    display: flex;
    gap: 10px;
}

.buttoncontainer{
    background: #66c1d1;
    border: none;
    padding: 8px;
    border-radius: 7px;
}
.summary{
    display: flex;
    gap: 15px;
    margin: 20px;
}

.card{
    flex: 1;
    background: #f1804b;
    padding: 20px;
    border-radius: 12px;
    text-align: center;

}
.tabs{
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    justify-content: center;

}

.tabs button{
    padding: 8px;
    border-radius: 20px;
    background: rgb(190, 96, 219);
}

.notifications{
    display: flex;
    flex-direction: column;
    gap: 15px;
    
}
.notification{
    display: flex;
    align-items: flex-start;
    gap: 15px;
    background: white;
    padding: 12px;
    border-radius: 12px;
    position: relative;
}
.content h3{
    font-size: 16px;
}

.content p{
    font-size: 14px;
    color: gray;
    margin: 5px;
}
.actions{
    margin-top: 5px;
}
.actions button{
    border: none;
    padding: 5px;
    margin-right: 5px;
    border-radius: 6px;

}

.read{
    background: #f1d34b;
    color: rgb(16, 26, 22);
}
.delete{
    background: #f1804b;
    color: rgb(30, 51, 51);
}

.time{
    position: absolute;
    right: 15px;
    top: 15px;
    font-size: 12px;
    color: gray;
}

@media(max-width: 768px) {
    .summary{
        flex-direction: column;
    }
    .notification{
        flex-direction: column;
    }
    .time{
        position: static;
        margin-top: 10px;

    }

    .header{
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
}
